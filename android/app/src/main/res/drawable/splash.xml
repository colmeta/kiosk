<?xml version="1.0" encoding="utf-8"?>
<!--
    Ngabo Splash Screen Drawable
    Background: Midnight Navy #0D1425
    Text/Icon:  Ngabo Gold   #D4AF37
    This renders as the centered icon on the Android 12+ splash screen.
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Solid navy background -->
    <item>
        <color android:color="#0D1425" />
    </item>

    <!-- Centered logo mark: stylised "N" letterform in gold -->
    <item
        android:gravity="center"
        android:width="120dp"
        android:height="120dp">
        <shape android:shape="rectangle">
            <solid android:color="#00000000" />
        </shape>
    </item>

    <!-- Gold accent ring behind the icon -->
    <item
        android:gravity="center"
        android:width="108dp"
        android:height="108dp">
        <shape android:shape="oval">
            <solid android:color="#1AD4AF37" />
            <stroke
                android:width="2dp"
                android:color="#D4AF37" />
        </shape>
    </item>

</layer-list>
