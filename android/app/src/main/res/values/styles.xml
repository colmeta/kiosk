<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base application theme -->
    <style name="AppTheme" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="colorPrimary">#0D1425</item>
        <item name="colorPrimaryDark">#0D1425</item>
        <item name="colorAccent">#D4AF37</item>
        <item name="android:windowBackground">#0D1425</item>
        <item name="android:statusBarColor">#0D1425</item>
    </style>

    <!-- Immersive no-action-bar theme for the main WebView -->
    <style name="AppTheme.NoActionBar" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:windowBackground">#0D1425</item>
        <item name="android:statusBarColor">#0D1425</item>
        <item name="android:navigationBarColor">#0D1425</item>
    </style>

    <!--
        Ngabo Splash Screen Theme
        Uses Android 12+ SplashScreen API via core-splashscreen library.
        Background: Midnight Navy #0D1425
        Icon tint: Ngabo Gold #D4AF37
    -->
    <style name="AppTheme.NoActionBarLaunch" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#0D1425</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/splash</item>
        <item name="postSplashScreenTheme">@style/AppTheme.NoActionBar</item>
        <item name="android:statusBarColor">#0D1425</item>
        <item name="android:navigationBarColor">#0D1425</item>
    </style>

</resources>